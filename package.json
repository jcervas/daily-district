{
  "name": "daily-district",
  "private": true,
  "type": "module",
  "description": "Daily District — deps are only for automation scripts (scripts/ and social/scripts/); the site itself is static and dependency-free.",
  "scripts": {
    "tweet": "node social/scripts/post-daily-tweet.mjs",
    "tweet:dry": "DRY_RUN=1 node social/scripts/post-daily-tweet.mjs",
    "build:map": "node scripts/build-districts-map.mjs",
    "build:pages": "node scripts/build-district-pages.mjs",
    "social": "node social/scripts/generate-social-graphics.mjs",
    "teaser": "node scripts/build-teaser.mjs",
    "teaser1": "node social/scripts/build-teaser-1.mjs",
    "teaser2": "node social/scripts/build-teaser-2.mjs",
    "teaser3": "node social/scripts/build-teaser-3.mjs",
    "teaser4": "node social/scripts/build-teaser-4.mjs",
    "teaser5": "node social/scripts/build-teaser-5.mjs",
    "teaser6": "node social/scripts/build-teaser-6.mjs",
    "teaser7": "node social/scripts/build-teaser-7.mjs",
    "teaser8": "node social/scripts/build-teaser-8.mjs",
    "teaser9": "node social/scripts/build-teaser-9.mjs",
    "teaser10": "node social/scripts/build-teaser-10.mjs",
    "render": "node social/scripts/render-mp4.mjs",
    "card": "node social/scripts/build-social-card.mjs",
    "recap:dry": "DRY_RUN=1 node social/scripts/daily-recap.mjs"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "d3-geo": "^3.1.1",
    "flubber": "^0.4.2",
    "topojson-client": "^3.1.0",
    "twitter-api-v2": "^1.27.0"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "puppeteer-core": "^25.3.0"
  }
}
